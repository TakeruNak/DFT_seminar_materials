&PROJWFC
  prefix = 'silicon'
  outdir = './out'
  ngauss = 0
  ! 0 ... Simple Gaussian (default) 
  ! 1 ... Methfessel-Paxton of order 1 
  ! -1 ... "cold smearing" (Marzari-Vanderbilt-DeVita-Payne) 
  ! -99 ... Fermi-Dirac function
  degauss = 0.01       ! Gaussian Broadening (Ry)
  DeltaE = 0.01        ! Energy grid step (eV)
  filpdos = 'silicon.pdos' ! prefix of output file
/

! reference :https://www.quantum-espresso.org/Doc/INPUT_PROJWFC.html
